{
  "name": "@evoscientist/webui",
  "version": "0.0.4",
  "description": "Web UI for EvoScientist — a self-evolving AI scientist built on DeepAgents/LangGraph.",
  "author": "Xi Zhang <zacharyzhang2022@gmail.com>",
  "type": "module",
  "license": "Apache-2.0",
  "keywords": [
    "evoscientist",
    "ai-scientist",
    "research",
    "deepagents",
    "langgraph",
    "chat-ui",
    "webui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EvoScientist/EvoScientist-WebUI.git"
  },
  "bugs": {
    "url": "https://github.com/EvoScientist/EvoScientist-WebUI/issues"
  },
  "homepage": "https://github.com/EvoScientist/EvoScientist-WebUI#readme",
  "bin": {
    "evoscientist-webui": "./bin/evoscientist-webui.mjs"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "next dev --turbopack --port 4716",
    "build": "next build && node scripts/assemble-standalone.mjs",
    "start": "next start --port 4716",
    "start:dist": "node dist/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph-sdk": "^1.9.18",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^9.0.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^1.2.1",
    "lucide-react": "^0.539.0",
    "next": "^16.2.7",
    "nuqs": "^2.8.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^9.0.1",
    "react-resizable-panels": "^3.0.6",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.6",
    "use-stick-to-bottom": "^1.1.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.24",
    "eslint": "^9",
    "eslint-config-next": "^16.2.7",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4",
    "postcss": "^8.5.6",
    "prettier": "^2.8.8",
    "prettier-plugin-tailwindcss": "^0.3.0",
    "tailwindcss": "^3.4.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
